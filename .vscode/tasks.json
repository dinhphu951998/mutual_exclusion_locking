{
    "version": "2.0.0",
    "tasks": [
      {
        "label": "Build with MSYS2 GCC (UCRT64)",
        "type": "shell",
        "command": "C:/msys64/ucrt64/bin/g++.exe",
        "args": [
          "-g",
          "-std=c++20",
          "-fopenmp",
          "-pthread",
          "${file}",
          "-o",
          "${fileDirname}/${fileBasenameNoExtension}.exe"
        ],
        "options": {
          "cwd": "${fileDirname}"
        },
        "group": {
          "kind": "build",
          "isDefault": true
        }
      },
      {
        "label": "Run file",
        "type": "shell",
        "command": "${fileBasenameNoExtension}.exe",
        "options": {
          "cwd": "${fileDirname}"
        },
        "dependsOn": "Build with MSYS2 GCC (UCRT64)",
        "dependsOrder": "sequence",
        "problemMatcher": [],
        "presentation": {
          "reveal": "always",
          "panel": "shared",
          "focus": true
        }
      }
    ]
  }